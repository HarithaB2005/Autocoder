# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────
API_SECRET_KEY=change-me-in-production
AUTH_ENABLED=true

# ── Validation ────────────────────────────────────────
VALIDATION_MAX_RETRIES=3

# ── LLM Defaults ─────────────────────────────────────
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.2
DEFAULT_TIMEOUT_SECONDS=120

# ── Memory ────────────────────────────────────────────
MEMORY_WINDOW_SIZE=10

# ── Output ───────────────────────────────────────────
AUTO_SAVE_DIR=generated_output

# ── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=["*"]

# ══════════════════════════════════════════════════════
# ── GPU Endpoint Configuration ────────────────────────
# ══════════════════════════════════════════════════════
# Paste your GPU URLs below and fill in your department value.
# Copy this file to .env and fill in the values.

GPU_URL_QWEN=https://your-qwen-url-here
GPU_URL_LLAMA=https://your-llama-url-here
GPU_URL_GEMMA=https://your-gemma-url-here

GPU_DEPARTMENT=YOUR_DEPARTMENT_HERE
GPU_ENV=prod
